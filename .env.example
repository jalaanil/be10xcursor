# Copy to .env.local and set your production URL for sitemap/OG metadata
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Supabase (from Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: use service role on the server for inserts if RLS is not enabled
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
